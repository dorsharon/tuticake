<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --rose:        #f4a7b9;
    --rose-mid:    #e8839e;
    --rose-dark:   #d4607e;
    --rose-deep:   #b03060;
    --blush:       #fce4ec;
    --blush-light: #fff0f4;
    --cream:       #fffaf9;
    --caramel:     #8b4a4a;
    --choco:       #5c2a2a;
    --soft-shadow: rgba(212, 96, 126, 0.18);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Heebo', sans-serif;
    background: var(--cream);
    color: var(--choco);
    overflow-x: hidden;
    direction: rtl;
    min-height: 100vh;
  }

  /* ── Petals ── */
  .petal-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .petal {
    position: absolute;
    top: -40px;
    animation: petalFall linear forwards;
    user-select: none;
  }
  @keyframes petalFall {
    0%   { transform: translateY(0) rotate(0deg) translateX(0); }
    50%  { transform: translateY(50vh) rotate(360deg) translateX(30px); }
    100% { transform: translateY(115vh) rotate(720deg) translateX(-20px); opacity: 0; }
  }

  /* ── Header ── */
  .header {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3.5rem 1.5rem 2rem;
    background: linear-gradient(180deg, #fff0f5 0%, var(--cream) 100%);
  }

  .logo-wrapper {
    position: relative;
    animation: logoIn 1.1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes logoIn {
    from { opacity: 0; transform: scale(0.55) rotate(-6deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  .logo-glow {
    position: absolute;
    inset: -24px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244,167,185,0.55) 0%, transparent 68%);
    animation: glow 3.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes glow {
    0%, 100% { transform: scale(1); opacity: 0.55; }
    50%       { transform: scale(1.12); opacity: 1; }
  }

  .logo {
    width: clamp(220px, 55vw, 290px);
    height: clamp(220px, 55vw, 290px);
    border-radius: 50%;
    object-fit: cover;
    position: relative;
    z-index: 1;
    box-shadow:
      0 0 0 5px #fff,
      0 0 0 9px var(--rose),
      0 0 0 12px rgba(244,167,185,0.3),
      0 24px 64px rgba(176,48,96,0.22),
      0 8px 24px rgba(212,96,126,0.18);
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .logo:hover { transform: scale(1.05) rotate(2deg); }

  .tagline-wrapper {
    text-align: center;
    margin-top: 2rem;
    animation: fadeUp 1s 0.35s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.15rem, 4vw, 1.75rem);
    font-weight: 300;
    font-style: italic;
    color: var(--rose-dark);
    letter-spacing: 0.05em;
  }

