  <script async src="//www.instagram.com/embed.js"></script>

  <script>
    // Floating petals
    const container = document.getElementById('petalContainer');
    const emojis = ['🌸', '✿', '🍓', '❀', '🌺'];
    function spawnPetal() {
      const el = document.createElement('span');
      el.className = 'petal';
      el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      el.style.cssText = `
        left:${Math.random() * 100}vw;
        font-size:${Math.random() * 14 + 10}px;
        animation-duration:${Math.random() * 10 + 7}s;
        animation-delay:${Math.random() * 3}s;
        opacity:${Math.random() * 0.35 + 0.08};
      `;
      container?.appendChild(el);
      el.addEventListener('animationend', () => el.remove());
    }
    for (let i = 0; i < 10; i++) setTimeout(spawnPetal, i * 300);
    setInterval(spawnPetal, 700);

    // Scroll reveal
    const io = new IntersectionObserver(entries => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          const delay = e.target.closest('.instagram-grid')
            ? [...e.target.parentElement.children].indexOf(e.target) * 120
            : 0;
          setTimeout(() => e.target.classList.add('visible'), delay);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // Lightbox
    const lightbox  = document.getElementById('menuLightbox');
    const openBtn   = document.getElementById('menuOpenBtn');
    const closeBtn  = document.getElementById('lightboxClose');
    const backdrop  = document.getElementById('lightboxBackdrop');

    function openLightbox() {
      lightbox.classList.add('open');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }
    function closeLightbox() {
      lightbox.classList.remove('open');
      document.body.style.overflow = '';
      openBtn.focus();
    }

    openBtn.addEventListener('click', openLightbox);
    closeBtn.addEventListener('click', closeLightbox);
    backdrop.addEventListener('click', closeLightbox);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && lightbox.classList.contains('open')) closeLightbox();
    });
  </script>

</body>
