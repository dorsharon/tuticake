---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Ribbon from '../components/Ribbon.astro';
import Gallery from '../components/Gallery.astro';
import PhotoLightbox from '../components/PhotoLightbox.astro';
import Menu from '../components/Menu.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { Font } from "astro:assets";
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="תותי קייק - עוגות יום הולדת מעוצבות, מארזי קינוחים ומתנות בהזמנה אישית. נשמח לבנות יחד את העוגה המושלמת לאירוע שלכם!" />
  <title>תותי קייק | עוגות מעוצבות וקינוחים בהזמנה</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="he_IL" />
  <meta property="og:title" content="תותי קייק | עוגות מעוצבות וקינוחים בהזמנה" />
  <meta property="og:description" content="עוגות יום הולדת מעוצבות, מארזי קינוחים ומתנות בהזמנה אישית." />
  <meta property="og:image" content="https://tuticake.com/og-image.jpg" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="תותי קייק | עוגות מעוצבות וקינוחים בהזמנה" />
  <meta name="twitter:description" content="עוגות יום הולדת מעוצבות, מארזי קינוחים ומתנות בהזמנה אישית." />
  <meta name="twitter:image" content="https://tuticake.com/og-image.jpg" />

  <!-- Theme color for mobile browsers -->
  <meta name="theme-color" content="#d4607e" />

  <!-- Fonts -->
  <Font cssVariable="--font-body" />

  <!-- Structured data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Bakery",
    "name": "תותי קייק",
    "description": "עוגות יום הולדת מעוצבות, מארזי קינוחים ומתנות בהזמנה אישית",
    "telephone": "+972546629179",
    "sameAs": ["https://www.instagram.com/tuti_cake/"],
    "priceRange": "₪₪",
    "areaServed": "מרכז הארץ",
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"],
        "opens": "09:00",
        "closes": "21:00"
      }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5"
    }
  }
  </script>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "כמה עולה עוגה מעוצבת?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "המחירים שלנו מתחילים מ-₪200 לעוגות קומה אחת ועולים בהתאם לעיצוב ולגודל. צרו קשר לקבלת הצעת מחיר אישית."
        }
      },
      {
        "@type": "Question",
        "name": "כמה זמן מראש צריך להזמין?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "מומלץ להזמין לפחות שבוע מראש, במיוחד בסופי שבוע."
        }
      },
      {
        "@type": "Question",
        "name": "האם אפשר לבקש עיצוב מותאם אישית?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "בהחלט! כל העוגות שלנו מעוצבות בהתאמה אישית מלאה."
        }
      }
    ]
  }
  </script>
</head>
<body>

  <div class="petal-container" id="petalContainer" aria-hidden="true"></div>

  <Header />
  <main>
    <Ribbon />
    <Gallery />
    <PhotoLightbox />
    <Menu />
    <Contact />
  </main>
  <Footer />
  <script>
    // Floating petals — deferred until after load to avoid competing with FCP/LCP
    window.addEventListener('load', () => {
      const container = document.getElementById('petalContainer');
      const emojis = ['🌸', '✿', '🍓', '❀', '🌺'];
      function spawnPetal() {
        const el = document.createElement('span');
        el.className = 'petal';
        el.style.cssText = `
          left:${Math.random() * 100}vw;
          font-size:${Math.random() * 14 + 10}px;
          animation-duration:${Math.random() * 10 + 7}s;
          animation-delay:${Math.random() * 3}s;
          opacity:${Math.random() * 0.35 + 0.08};
        `;
        el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
        container?.appendChild(el);
        el.addEventListener('animationend', () => el.remove());
      }
      for (let i = 0; i < 10; i++) setTimeout(spawnPetal, i * 300);
      setInterval(spawnPetal, 700);
    });

    // Scroll reveal
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const i = parseInt((e.target as HTMLElement).style.getPropertyValue('--i') || '0');
          setTimeout(() => e.target.classList.add('visible'), i * 80);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>

</body>
</html>
