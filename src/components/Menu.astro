---
import { Image } from 'astro:assets';
import menuImg from '../assets/menu.png';
---

<section class="menu-section">
  <canvas id="sparkleCanvas" aria-hidden="true"></canvas>

  <div class="menu-content reveal">
    <p class="menu-eyebrow">המחירים שלנו</p>
    <h2 class="menu-title">תפריט</h2>
    <p class="menu-sub">עוגות מעוצבות, מארזי קינוחים ועוד</p>
    <button class="menu-btn" id="menuOpenBtn" aria-label="פתחו את התפריט">
      <span class="menu-btn-icon">🎂</span>
      לצפייה בתפריט המלא
      <svg class="menu-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      <span class="btn-shimmer" aria-hidden="true"></span>
    </button>
  </div>
</section>

<!-- Menu Lightbox -->
<div class="lightbox" id="menuLightbox" role="dialog" aria-modal="true" aria-label="תפריט מחירים">
  <div class="lightbox-backdrop" id="menuBackdrop"></div>
  <div class="lightbox-panel">
    <button class="lightbox-close" id="menuClose" aria-label="סגרו">✕</button>
    <div class="menu-lightbox-img-wrap">
      <Image
        src={menuImg}
        alt="תפריט מחירים תותי קייק"
        class="menu-lightbox-img"
        width={680}
        format="webp"
        quality={85}
      />
    </div>
  </div>
</div>

<script>
  const lightbox = document.getElementById('menuLightbox')!;
  const openBtn  = document.getElementById('menuOpenBtn')!;
  const closeBtn = document.getElementById('menuClose')!;
  const backdrop = document.getElementById('menuBackdrop')!;

  function openLightbox() {
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeLightbox() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
    openBtn.focus();
  }

  openBtn.addEventListener('click', openLightbox);
  closeBtn.addEventListener('click', closeLightbox);
  backdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && lightbox.classList.contains('open')) closeLightbox();
  });

  /* ── Sparkle canvas ── */
  const canvas = document.getElementById('sparkleCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0;

  interface Sparkle {
    x: number; y: number; r: number;
    vx: number; vy: number;
    alpha: number; fade: number;
    hue: number;
  }
  const sparkles: Sparkle[] = [];
  const MAX = 55;

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = canvas.width  = rect.width;
    H = canvas.height = rect.height;
  }
  resize();
  window.addEventListener('resize', resize);

  function addSparkle() {
    sparkles.push({
      x: Math.random() * W,
      y: H + 10,
      r: Math.random() * 3 + 1,
      vx: (Math.random() - 0.5) * 0.8,
      vy: -(Math.random() * 0.7 + 0.3),
      alpha: Math.random() * 0.5 + 0.3,
      fade: Math.random() * 0.003 + 0.002,
      hue: Math.random() * 30 + 330,
    });
  }

  function drawSparkles() {
    ctx.clearRect(0, 0, W, H);
    if (sparkles.length < MAX && Math.random() < 0.3) addSparkle();
    for (let i = sparkles.length - 1; i >= 0; i--) {
      const s = sparkles[i];
      s.x += s.vx; s.y += s.vy; s.alpha -= s.fade;
      if (s.alpha <= 0 || s.y < -10) { sparkles.splice(i, 1); continue; }
      ctx.save();
      ctx.globalAlpha = s.alpha;
      ctx.fillStyle = `hsl(${s.hue}, 75%, 70%)`;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
    requestAnimationFrame(drawSparkles);
  }
  drawSparkles();
</script>

<style>
  .menu-section {
    position: relative;
    z-index: 5;
    padding: 3rem 1.5rem 3rem;
    background: linear-gradient(160deg, var(--cream) 0%, var(--blush-light) 100%);
    text-align: center;
    overflow: hidden;
  }

  #sparkleCanvas {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .menu-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .menu-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--rose-mid);
    text-transform: uppercase;
  }

  .menu-title {
    font-size: clamp(2.2rem, 7vw, 3.8rem);
    font-weight: 400;
    color: var(--choco);
    line-height: 1;
    display: inline-block;
  }
  .menu-title::after {
    content: '';
    display: block;
    width: 60%;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--rose-dark), transparent);
    margin: 0.4rem auto 0;
    border-radius: 2px;
  }

  .menu-sub {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--rose-dark);
    margin-bottom: 0.8rem;
  }

  .menu-btn {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 0.6rem;
    background: linear-gradient(135deg, var(--rose-dark) 0%, var(--rose-deep) 100%);
    color: white;
    border: none;
    cursor: pointer;
    padding: 1rem 2.4rem;
    border-radius: 50px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.03em;
    box-shadow: 0 8px 30px rgba(176,48,96,0.3);
    transition: transform 0.38s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }
  .btn-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.45) 50%, transparent 70%);
    background-size: 200% 100%;
    background-position: 150% 0;
    border-radius: inherit;
    animation: btnShimmer 3s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes btnShimmer {
    0%, 60% { background-position: 150% 0; }
    80%      { background-position: -50% 0; }
    100%     { background-position: -50% 0; }
  }
  .menu-btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 18px 44px rgba(176,48,96,0.42);
  }
  .menu-btn-icon { font-size: 1.2rem; }
  .menu-arrow { width: 18px; height: 18px; }

  /* Menu lightbox panel */
  .lightbox-panel {
    position: relative;
    z-index: 1;
    border-radius: 24px;
    box-shadow: 0 32px 80px rgba(92,42,42,0.35);
    overflow: hidden;
    transform: scale(0.88) translateY(20px);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    line-height: 0;
    max-width: min(680px, calc(100vw - 2rem));
    max-height: 90vh;
  }
  .lightbox.open .lightbox-panel { transform: scale(1) translateY(0); }

  .menu-lightbox-img-wrap { display: block; }
  .menu-lightbox-img { display: block; width: 100%; height: auto; max-height: 90vh; object-fit: contain; }
</style>
