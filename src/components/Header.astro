---
import { Image } from 'astro:assets';
import logo from '../assets/logo.jpg';
---

<header class="header">
  <div class="logo-wrapper">
    <div class="logo-glow"></div>
    <Image src={logo} alt="תותי קייק לוגו" class="logo" width={290} height={290} format="webp" quality={85} fetchpriority="high" loading="eager" />
  </div>
</header>

<style>
  .header {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3.5rem 1.5rem 2.5rem;
    background: linear-gradient(180deg, #fff0f5 0%, var(--cream) 100%);
  }

  .logo-wrapper {
    position: relative;
    animation: logoIn 1.1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes logoIn {
    from { opacity: 0; transform: scale(0.55) rotate(-6deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  .logo-glow {
    position: absolute;
    inset: -24px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244,167,185,0.55) 0%, transparent 68%);
    animation: glow 3.5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { transform: scale(1); opacity: 0.55; }
    50%       { transform: scale(1.12); opacity: 1; }
  }

  .logo {
    width: clamp(220px, 55vw, 290px);
    height: clamp(220px, 55vw, 290px);
    border-radius: 50%;
    object-fit: cover;
    position: relative;
    z-index: 1;
    box-shadow:
      0 0 0 5px #fff,
      0 0 0 9px var(--rose),
      0 0 0 12px rgba(244,167,185,0.3),
      0 24px 64px rgba(176,48,96,0.22),
      0 8px 24px rgba(212,96,126,0.18);
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo:hover { transform: scale(1.05) rotate(2deg); }

  @media (max-width: 600px) {
    .header { padding: 2.2rem 1rem 2rem; }
  }
</style>
