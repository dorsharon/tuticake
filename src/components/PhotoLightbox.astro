---
---

<div class="lightbox photo-lightbox" id="photoLightbox" role="dialog" aria-modal="true" aria-label="תמונה מוגדלת מהגלריה">
  <div class="lightbox-backdrop" id="photoBackdrop"></div>
  <div class="photo-lightbox-panel">
    <button class="lightbox-close" id="photoClose" aria-label="סגרו">✕</button>
    <button class="photo-nav photo-prev" id="photoPrev" aria-label="הקודם">›</button>
    <button class="photo-nav photo-next" id="photoNext" aria-label="הבא">‹</button>
    <div class="photo-lightbox-img-wrap">
      <img id="photoLightboxImg" src="" alt="" class="photo-lightbox-img" />
    </div>
    <p class="photo-lightbox-caption" id="photoLightboxCaption"></p>
    <a
      id="photoWhatsappBtn"
      class="photo-whatsapp-btn"
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="שלחי הודעה בוואטסאפ"
    >
      <svg class="photo-whatsapp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      כזה אני רוצה!
    </a>
  </div>
</div>

<script>
  const photoLightbox   = document.getElementById('photoLightbox')!;
  const photoImg        = document.getElementById('photoLightboxImg') as HTMLImageElement;
  const photoCaption    = document.getElementById('photoLightboxCaption')!;
  const photoClose      = document.getElementById('photoClose')!;
  const photoBackdrop   = document.getElementById('photoBackdrop')!;
  const photoPrev       = document.getElementById('photoPrev')!;
  const photoNext       = document.getElementById('photoNext')!;
  const photoWhatsappBtn = document.getElementById('photoWhatsappBtn') as HTMLAnchorElement;

  const cards = Array.from(document.querySelectorAll<HTMLElement>('.photo-card'));
  let currentPhoto = 0;

  function showPhoto(index: number) {
    currentPhoto = (index + cards.length) % cards.length;
    const card = cards[currentPhoto];
    const src = card.dataset.src ?? card.querySelector<HTMLImageElement>('.photo-img')!.src;
    const alt = card.dataset.alt ?? '';
    photoImg.src = src;
    photoImg.alt = alt;
    photoCaption.textContent = alt;
    const waMessage = encodeURIComponent(`היי! ראיתי באתר את התמונה של ״${alt}״ והייתי רוצה להזמין משהו כזה`);
    photoWhatsappBtn.href = `https://wa.me/972546629179?text=${waMessage}`;
    photoLightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closePhoto() {
    photoLightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  cards.forEach((card, i) => {
    card.addEventListener('click', () => showPhoto(i));
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); showPhoto(i); }
    });
  });

  photoClose.addEventListener('click', closePhoto);
  photoBackdrop.addEventListener('click', closePhoto);
  photoPrev.addEventListener('click', (e: MouseEvent) => { e.stopPropagation(); showPhoto(currentPhoto - 1); });
  photoNext.addEventListener('click', (e: MouseEvent) => { e.stopPropagation(); showPhoto(currentPhoto + 1); });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!photoLightbox.classList.contains('open')) return;
    if (e.key === 'ArrowLeft')  showPhoto(currentPhoto - 1);
    if (e.key === 'ArrowRight') showPhoto(currentPhoto + 1);
    if (e.key === 'Escape')     closePhoto();
  });
</script>

<style>
  .photo-lightbox-panel {
    position: relative;
    z-index: 1;
    max-width: min(860px, 96vw);
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: scale(0.88) translateY(20px);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .photo-lightbox.open .photo-lightbox-panel { transform: scale(1) translateY(0); }

  .photo-lightbox-img-wrap {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.45);
    max-height: 80vh;
    display: flex;
  }

  .photo-lightbox-img {
    max-width: min(860px, 92vw);
    max-height: 80vh;
    object-fit: contain;
    display: block;
    border-radius: 16px;
  }

  .photo-lightbox-caption {
    margin-top: 0.8rem;
    color: rgba(255,255,255,0.8);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .photo-nav {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.25);
    color: white;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 3px; /* optical centering of › ‹ glyphs */
    transition: background 0.2s, transform 0.2s;
    z-index: 2;
  }
  .photo-nav:hover { background: rgba(255,255,255,0.3); transform: translateY(-50%) scale(1.1); }
  .photo-prev { right: calc(100% + 12px); }
  .photo-next { left: calc(100% + 12px); }

  .photo-whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.65rem 1.4rem;
    background: #25D366;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    direction: rtl;
  }
  .photo-whatsapp-btn:hover {
    background: #1ebe5d;
    transform: scale(1.05);
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.6);
  }
  .photo-whatsapp-icon {
    width: 1.2em;
    height: 1.2em;
    flex-shrink: 0;
  }

  @media (max-width: 700px) {
    .photo-prev { right: auto; left: 6px; top: auto; bottom: -56px; transform: none; }
    .photo-next { left: auto; right: 6px; top: auto; bottom: -56px; transform: none; }
    .photo-nav:hover { transform: scale(1.1); }
  }
</style>
