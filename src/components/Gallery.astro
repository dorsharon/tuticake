---
import { Image } from 'astro:assets';

// Import all gallery images statically for Astro optimization
import img01 from '../assets/gallery/01.jpg';
import img02 from '../assets/gallery/02.jpg';
import img03 from '../assets/gallery/03.jpg';
import img04 from '../assets/gallery/04.jpg';
import img05 from '../assets/gallery/05.jpg';
import img06 from '../assets/gallery/06.jpg';
import img07 from '../assets/gallery/07.jpg';
import img08 from '../assets/gallery/08.jpg';
import img09 from '../assets/gallery/09.jpg';
import img10 from '../assets/gallery/10.jpg';
import img11 from '../assets/gallery/11.jpg';

const galleryImages = [
  { src: img01, alt: 'עוגת גן גודל A4' },
  { src: img02, alt: 'מארז קינוחים' },
  { src: img03, alt: 'מארז קינוחים מעוצב' },
  { src: img04, alt: 'עוגת יום הולדת' },
  { src: img05, alt: 'עוגה מעוצבת עם פרחים' },
  { src: img06, alt: 'מארז בראוניז' },
  { src: img07, alt: 'עוגת חד קרן' },
  { src: img08, alt: 'עוגה מעוצבת' },
  { src: img09, alt: 'מארז קאפקייקס' },
  { src: img10, alt: 'עוגת מין הילד' },
  { src: img11, alt: 'עוגת גן עם תמונה' },
];
---

<section class="gallery-section">
  <div class="section-header reveal">
    <h2 class="section-title">הגלריה שלנו</h2>
    <p class="section-sub">כל יצירה מספרת סיפור</p>
  </div>

  <div class="photo-grid">
    {galleryImages.map((img, i) => (
      <div
        class="photo-card reveal"
        style={`--i:${i}`}
        data-src={img.src.src}
        data-alt={img.alt}
        role="button"
        tabindex="0"
        aria-label={`הגדל תמונה: ${img.alt}`}
      >
        <div class="photo-img-wrap">
          <Image
            src={img.src}
            alt={img.alt}
            class="photo-img"
            width={600}
            height={600}
            format="webp"
            quality={80}
            loading="lazy"
          />
          <div class="photo-overlay">
            <svg class="overlay-zoom-icon" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/>
            </svg>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="ig-cta reveal">
    <a href="https://www.instagram.com/tuti_cake/" target="_blank" rel="noopener" class="ig-follow-btn">
      <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
      </svg>
      עקבו אחרינו באינסטגרם
    </a>
  </div>
</section>

<style>
  .gallery-section {
    padding: 5rem 1.5rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 5;
  }

  .section-header { text-align: center; margin-bottom: 3.5rem; }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 7vw, 3.6rem);
    font-weight: 900;
    color: var(--choco);
    line-height: 1.1;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    display: block;
    width: 65%;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--rose-dark), transparent);
    margin: 0.5rem auto 0;
    border-radius: 2px;
  }

  .section-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-style: italic;
    color: var(--rose-dark);
    margin-top: 0.6rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .photo-grid { grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  }

  .photo-card {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--blush);
    box-shadow: 0 4px 20px var(--soft-shadow);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
    cursor: pointer;
  }
  .photo-card:hover {
    transform: scale(1.04) translateY(-4px);
    box-shadow: 0 16px 44px var(--soft-shadow);
  }
  .photo-card:hover .photo-overlay { opacity: 1; }
  .photo-card:hover .photo-img { transform: scale(1.07); }
  .photo-card:focus { outline: 2px solid var(--rose-dark); outline-offset: 3px; }

  .photo-img-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: rgba(176, 48, 96, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .overlay-zoom-icon {
    width: 36px;
    height: 36px;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
  }

  .ig-cta { text-align: center; margin-top: 2.5rem; }

  .ig-follow-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    color: white;
    text-decoration: none;
    padding: 0.9rem 2.2rem;
    border-radius: 50px;
    font-family: 'Assistant', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.04em;
    box-shadow: 0 8px 28px rgba(188,24,136,0.3);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }
  .ig-follow-btn:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 16px 40px rgba(188,24,136,0.42);
  }

  .btn-icon { width: 20px; height: 20px; flex-shrink: 0; }

  @media (max-width: 600px) {
    .gallery-section { padding: 3rem 0.8rem 3rem; }
  }
</style>
