<style>
  .contact-section {
    position: relative;
    overflow: hidden;
    padding: 6rem 2rem 7rem;
    background: linear-gradient(160deg, #fff0f5 0%, #fce4ec 45%, #fff5f8 100%);
    text-align: center;
  }

  .contact-bg-deco {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 15% 50%, rgba(244,167,185,0.35) 0%, transparent 45%),
      radial-gradient(circle at 85% 50%, rgba(212,96,126,0.22) 0%, transparent 45%),
      radial-gradient(circle at 50% 100%, rgba(244,167,185,0.2) 0%, transparent 50%);
    pointer-events: none;
  }

  .contact-content {
    position: relative;
    z-index: 2;
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-icon-wrap {
    font-size: 2.5rem;
    color: var(--rose-dark);
    animation: heartbeat 1.8s ease-in-out infinite;
    display: block;
    margin-bottom: 0.8rem;
  }

  .contact-title {
    font-size: clamp(2.4rem, 8vw, 4.2rem);
    font-weight: 900;
    font-style: italic;
    color: var(--rose-deep);
    line-height: 1;
    margin-bottom: 0.8rem;
  }

  .contact-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    color: var(--caramel);
    font-style: italic;
    margin-bottom: 2.8rem;
  }

  .contact-buttons {
    display: flex;
    gap: 1.4rem;
    justify-content: center;
  }

  .contact-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    text-decoration: none;
    transition: transform 0.38s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }
  .contact-icon-btn svg { width: 28px; height: 28px; }
  .contact-icon-btn:hover { transform: translateY(-6px) scale(1.12); }

  .whatsapp-btn {
    background: #25D366;
    box-shadow: 0 8px 28px rgba(37,211,102,0.4);
  }
  .whatsapp-btn svg { fill: white; }
  .whatsapp-btn:hover { box-shadow: 0 16px 44px rgba(37,211,102,0.55); }

  .phone-btn {
    background: white;
    border: 2px solid var(--rose);
    box-shadow: 0 6px 22px var(--soft-shadow);
  }
  .phone-btn svg { fill: var(--rose-deep); }
  .phone-btn:hover { background: var(--rose); box-shadow: 0 14px 38px var(--soft-shadow); }
  .phone-btn:hover svg { fill: white; }

  @media (max-width: 600px) {
    .contact-section { padding: 4rem 1.2rem 5rem; }
    .contact-icon-btn { width: 58px; height: 58px; }
    .contact-icon-btn svg { width: 25px; height: 25px; }
  }
</style>
